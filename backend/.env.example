# Copy to .env for local runs, or set these as environment variables on your host.

# --- Required ---
MONGO_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=fungame

# --- Recommended ---
JWT_SECRET=change-me-to-a-long-random-string
CORS_ORIGINS=*

# --- Email (leave as demo to skip email setup; signup code is returned in the API response) ---
APP_ENV=development
EMAIL_PROVIDER=demo
# To send real emails instead, set EMAIL_PROVIDER=resend and:
# RESEND_API_KEY=
# SENDER_EMAIL=onboarding@resend.dev
